# OpenAI配置
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo-0125
EMBEDDING_MODEL=text-embedding-3-small

# MySQL配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=agi_user
MYSQL_PASSWORD=agi_password
MYSQL_DATABASE=agi_assistant

# PostgreSQL配置
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agi_user
POSTGRES_PASSWORD=agi_password
POSTGRES_DATABASE=agi_assistant

# 数据库切换（可选）
# DATABASE_URL_OVERRIDE=postgresql+psycopg2://agi_user:agi_password@postgres:5432/agi_assistant

# 应用配置
MAX_TOKENS=4096
TEMPERATURE=0.0
MEMORY_WINDOW_SIZE=10
LONG_TERM_MEMORY_TOP_K=3
RAG_TOP_K=5
